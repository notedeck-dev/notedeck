{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "NoteDeck",
  "version": "1.3.11",
  "identifier": "com.notedeck.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "NoteDeck",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "shadow": false,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "enableGTKAppId": false,
    "macOSPrivateApi": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; worker-src 'self' blob: data:; style-src 'self' 'unsafe-inline' https://*; img-src 'self' asset: http://asset.localhost data: blob: https://* http://127.0.0.1:19820; media-src 'self' https://*; font-src 'self' data: https://*; connect-src ipc: http://ipc.localhost http://tauri.localhost http://127.0.0.1:19820 http://localhost:* https://* data: blob:; frame-src http://127.0.0.1:19820 https://*",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["notedeck"]
      }
    },
    "opener": {},
    "updater": {
      "endpoints": [
        "https://github.com/hitalin/notedeck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMkJCREMzMjU3MzgwNTMKUldSVGdITWx3NzByOEtiTk5tOVU4cFB0aXFGTWh5b3lydy9PSjM5dWExekNTRGZXZHFiZHBRMHoK"
    }
  }
}

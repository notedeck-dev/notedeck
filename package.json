{
  "name": "notedeck",
  "description": "Misskey Pro — integrated deck environment (IDE) for Misskey power users",
  "private": true,
  "version": "1.18.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "vue-tsc -b --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "pnpm android:dev",
    "tauri:android:build": "pnpm android:build",
    "tauri:ios": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "android:sync": "./src-tauri/android/sync.sh",
    "android:dev": "pnpm android:sync && tauri android dev",
    "android:build": "pnpm android:sync && tauri android build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changelog": "git log $(git describe --tags --abbrev=0 2>/dev/null || echo '')..HEAD --pretty=format:'- %s' --no-merges",
    "icons": "tauri icon src-tauri/icons/icon.svg -o src-tauri/icons",
    "clean": "rm -rf dist src-tauri/target"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/lsp-client": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@scalar/api-reference": "^1.60.0",
    "@syuilo/aiscript": "^1.2.1",
    "@syuilo/aiscript-0-19-0": "npm:@syuilo/aiscript@^0.19.0",
    "@tabler/icons-webfont": "^3.44.0",
    "@tanstack/vue-virtual": "^3.13.29",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-haptics": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/core": "^14.3.0",
    "blurhash": "^2.0.5",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-matrix": "^3.0.4",
    "chartjs-plugin-gradient": "^0.6.1",
    "colord": "^2.9.3",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "js-yaml": "^4.2.0",
    "json5": "^2.2.3",
    "katex": "^0.16.47",
    "pinia": "^3.0.4",
    "qr-code-styling": "^1.9.2",
    "shiki": "^4.2.0",
    "vue": "^3.5.38",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.13.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.10.6",
    "lefthook": "^2.1.9",
    "lightningcss": "^1.32.0",
    "postcss": "8.5.18",
    "sass": "^1.101.0",
    "subset-font": "^2.5.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^3.2.6",
    "vue-tsc": "^3.3.5",
    "ws": "^8.21.0"
  }
}

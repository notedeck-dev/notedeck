{
  "name": "notedeck",
  "description": "Misskey IDE — integrated deck environment for browsing, posting, searching, and connecting",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc -b --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "tauri:ios": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "android:sync": "./src-tauri/android/sync.sh",
    "android:dev": "pnpm android:sync && tauri android dev",
    "android:build": "pnpm android:sync && tauri android build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changelog": "git log $(git describe --tags --abbrev=0 2>/dev/null || echo '')..HEAD --pretty=format:'- %s' --no-merges",
    "icons": "tauri icon src-tauri/icons/icon.svg -o src-tauri/icons",
    "clean": "rm -rf dist src-tauri/target"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.4",
    "@codemirror/lsp-client": "^6.2.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15",
    "@lezer/highlight": "^1.2.3",
    "@scalar/api-reference": "^1.48.4",
    "@syuilo/aiscript": "^1.2.1",
    "@syuilo/aiscript-0-19-0": "npm:@syuilo/aiscript@^0.19.0",
    "@tabler/icons-webfont": "^3.37.1",
    "@tanstack/vue-virtual": "^3.13.23",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-haptics": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@vueuse/core": "^14.2.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-chart-matrix": "^3.0.0",
    "chartjs-plugin-gradient": "^0.6.1",
    "colord": "^2.9.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "js-yaml": "^4.1.1",
    "json5": "^2.2.3",
    "katex": "^0.16.38",
    "pinia": "^3.0.3",
    "qr-code-styling": "^1.9.2",
    "shiki": "^4.0.0",
    "vue": "^3.5.25",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.8.8",
    "lefthook": "^2.1.4",
    "lightningcss": "^1.32.0",
    "sass": "^1.98.0",
    "subset-font": "^2.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.1",
    "vue-tsc": "^3.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}

// NoteDeck デフォルトキーバインド
//
// VSCode の keybindings.json と同じ思想:
// デフォルトキーバインドを定義し、ユーザーが上書きできる。
//
// scope:
//   "global" - 修飾キー付き、常に有効 (Ctrl+K 等)
//   "body"   - テキスト入力中は無効 (単キー: p, n 等)
[
  // ── General ──
  {
    commandId: "command-palette",
    shortcuts: [
      { key: "k", ctrl: true, scope: "global" },
      { key: "/", scope: "body" },
      { key: "?", scope: "body" },
    ],
  },
  {
    commandId: "search",
    shortcuts: [
      { key: "f", ctrl: true, shift: true, scope: "global" },
      { key: "s", scope: "body" },
    ],
  },
  {
    commandId: "notifications",
    shortcuts: [{ key: "i", scope: "body" }],
  },
  {
    commandId: "compose",
    shortcuts: [
      { key: "p", scope: "body" },
      { key: "n", scope: "body" },
      { key: "n", ctrl: true, shift: true, scope: "global" },
    ],
  },
  {
    commandId: "add-column",
    shortcuts: [{ key: "a", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "toggle-sidebar",
    shortcuts: [{ key: "\\", ctrl: true, scope: "global" }],
  },
  {
    commandId: "boss-key",
    shortcuts: [{ key: "b", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "account-menu",
    shortcuts: [{ key: "a", scope: "body" }],
  },
  {
    commandId: "profile-menu",
    shortcuts: [{ key: "g", scope: "body" }],
  },
  {
    commandId: "settings-menu",
    shortcuts: [{ key: ",", ctrl: true, scope: "global" }],
  },
  {
    // チュートリアル: F1 が help/guide 系の universal convention
    commandId: "tutorial",
    shortcuts: [{ key: "F1", scope: "global" }],
  },
  {
    commandId: "toggle-dark-mode",
    shortcuts: [{ key: "d", scope: "body" }],
  },

  {
    commandId: "close-column",
    shortcuts: [{ key: "w", ctrl: true, scope: "global" }],
  },
  {
    commandId: "keybinds",
    shortcuts: [{ key: "k", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "css-editor",
    shortcuts: [{ key: "u", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "tasks-editor",
    shortcuts: [{ key: "j", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "tasks.run-default",
    shortcuts: [{ key: "b", ctrl: true, alt: true, scope: "global" }],
  },
  {
    commandId: "plugins",
    shortcuts: [{ key: "x", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "login",
    shortcuts: [{ key: "l", ctrl: true, shift: true, alt: true, scope: "global" }],
  },
  {
    commandId: "chat",
    shortcuts: [{ key: "c", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "ai",
    shortcuts: [{ key: "i", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "close-all-floating-windows",
    shortcuts: [{ key: "Escape", shift: true, scope: "global" }],
  },
  {
    commandId: "toggle-column-mute",
    shortcuts: [{ key: "m", scope: "body" }],
  },

  // ── Note navigation ──
  {
    commandId: "note-next",
    shortcuts: [{ key: "j", scope: "body" }],
  },
  {
    commandId: "note-prev",
    shortcuts: [{ key: "k", scope: "body" }],
  },
  {
    commandId: "note-reply",
    shortcuts: [
      { key: "r", scope: "body" },
      { key: "ArrowLeft", scope: "body" },
    ],
  },
  {
    commandId: "note-react",
    shortcuts: [
      { key: "e", scope: "body" },
      { key: "+", scope: "body" },
    ],
  },
  {
    commandId: "note-renote",
    shortcuts: [
      { key: "q", scope: "body" },
      { key: "ArrowRight", scope: "body" },
    ],
  },
  {
    commandId: "note-bookmark",
    shortcuts: [{ key: "b", scope: "body" }],
  },
  {
    commandId: "note-open",
    shortcuts: [
      { key: "Enter", scope: "body" },
      { key: "o", scope: "body" },
    ],
  },
  {
    commandId: "note-cw",
    shortcuts: [{ key: "v", scope: "body" }],
  },
  {
    commandId: "note-delete",
    shortcuts: [{ key: "Delete", scope: "body" }],
  },
  {
    commandId: "note-edit",
    shortcuts: [{ key: "e", shift: true, scope: "body" }],
  },
  {
    commandId: "note-copy-link",
    shortcuts: [{ key: "y", scope: "body" }],
  },
  {
    commandId: "note-copy-content",
    shortcuts: [{ key: "c", scope: "body" }],
  },

  // ── Column navigation ──
  {
    commandId: "column-next",
    shortcuts: [{ key: "l", shift: true, scope: "body" }],
  },
  {
    commandId: "column-prev",
    shortcuts: [{ key: "h", shift: true, scope: "body" }],
  },
  {
    commandId: "column-1",
    shortcuts: [{ key: "1", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-2",
    shortcuts: [{ key: "2", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-3",
    shortcuts: [{ key: "3", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-4",
    shortcuts: [{ key: "4", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-5",
    shortcuts: [{ key: "5", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-6",
    shortcuts: [{ key: "6", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-7",
    shortcuts: [{ key: "7", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-8",
    shortcuts: [{ key: "8", ctrl: true, scope: "global" }],
  },
  {
    commandId: "column-9",
    shortcuts: [{ key: "9", ctrl: true, scope: "global" }],
  },

  // ── Quick reactions ──
  {
    commandId: "quick-react-1",
    shortcuts: [{ key: "1", scope: "body" }],
  },
  {
    commandId: "quick-react-2",
    shortcuts: [{ key: "2", scope: "body" }],
  },
  {
    commandId: "quick-react-3",
    shortcuts: [{ key: "3", scope: "body" }],
  },
  {
    commandId: "quick-react-4",
    shortcuts: [{ key: "4", scope: "body" }],
  },
  {
    commandId: "quick-react-5",
    shortcuts: [{ key: "5", scope: "body" }],
  },
  {
    commandId: "quick-react-6",
    shortcuts: [{ key: "6", scope: "body" }],
  },
  {
    commandId: "quick-react-7",
    shortcuts: [{ key: "7", scope: "body" }],
  },
  {
    commandId: "quick-react-8",
    shortcuts: [{ key: "8", scope: "body" }],
  },
  {
    commandId: "quick-react-9",
    shortcuts: [{ key: "9", scope: "body" }],
  },
  {
    commandId: "quick-react-0",
    shortcuts: [{ key: "0", scope: "body" }],
  },

  // ── Deck profiles ──
  {
    commandId: "profile-1",
    shortcuts: [{ key: "1", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-2",
    shortcuts: [{ key: "2", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-3",
    shortcuts: [{ key: "3", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-4",
    shortcuts: [{ key: "4", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-5",
    shortcuts: [{ key: "5", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-6",
    shortcuts: [{ key: "6", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-7",
    shortcuts: [{ key: "7", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-8",
    shortcuts: [{ key: "8", alt: true, scope: "global" }],
  },
  {
    commandId: "profile-9",
    shortcuts: [{ key: "9", alt: true, scope: "global" }],
  },

  // ── Window management ──
  {
    commandId: "pop-out-column",
    shortcuts: [{ key: "o", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "new-window",
    shortcuts: [
      { key: "n", ctrl: true, shift: true, alt: true, scope: "global" },
    ],
  },
  {
    commandId: "close-all-windows",
    shortcuts: [{ key: "w", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "pip-window",
    shortcuts: [{ key: "p", ctrl: true, shift: true, scope: "global" }],
  },

  // ── Additional commands ──
  {
    commandId: "toggle-offline-mode",
    shortcuts: [{ key: "o", ctrl: true, shift: true, alt: true, scope: "global" }],
  },
  {
    commandId: "toggle-realtime-mode",
    shortcuts: [{ key: "r", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "move-column-left",
    shortcuts: [{ key: "h", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "move-column-right",
    shortcuts: [{ key: "l", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "profile-new",
    shortcuts: [{ key: "p", ctrl: true, shift: true, alt: true, scope: "global" }],
  },
  {
    commandId: "theme-editor",
    shortcuts: [{ key: "t", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "profile-editor",
    shortcuts: [{ key: "e", ctrl: true, shift: true, scope: "global" }],
  },
  {
    commandId: "devtools",
    shortcuts: [{ key: "F12", scope: "global" }],
  },
  {
    commandId: "settings-editor",
    shortcuts: [{ key: "a", ctrl: true, shift: true, alt: true, scope: "global" }],
  },
  {
    commandId: "clear-all-cache",
    shortcuts: [{ key: "k", ctrl: true, shift: true, alt: true, scope: "global" }],
  },
]
